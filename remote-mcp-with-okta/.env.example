# Server Configuration
PORT=3000
SERVER_BASE_URL=http://localhost:3000

# Okta OAuth Configuration
# Issuer: Your Okta Authorization Server URL
# Format: https://{your-okta-domain}/oauth2/{authorization-server-id}
# Example: https://dev-123456.okta.com/oauth2/default
OKTA_ISSUER=https://your-okta-domain.okta.com/oauth2/default

# Audience: The identifier for your resource server
# This should match the "Audience" setting in your Okta Authorization Server
# Typically your server's base URL or a custom identifier
OKTA_AUDIENCE=http://localhost:3000
